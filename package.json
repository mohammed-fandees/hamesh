{
  "name": "hamesh",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Contextual notes for the web — leave thoughts attached to the pages and elements they belong to.",
  "author": "Mohammed Fandees",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohammed-fandees/hamesh.git"
  },
  "bugs": {
    "url": "https://github.com/mohammed-fandees/hamesh/issues"
  },
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "icons": "node scripts/generate-icons.mjs",
    "og": "node scripts/generate-og.mjs",
    "assets": "pnpm icons && pnpm og",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "release:validate": "tsx tooling/release/cli/validate-release.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
